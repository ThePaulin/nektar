{
  "name": "nektar",
  "description": "A dense, timeline-first desktop and web video editor.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "productName": "Nektar",
  "author": "Nektar",
  "scripts": {
    "dev": "node scripts/run-dev-server.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "npm run desktop:build && node electron/run-desktop-dev.mjs",
    "desktop:build": "npm run build && tsc -p electron/tsconfig.json",
    "ffmpeg:fetch": "node scripts/fetch-ffmpeg-binaries.mjs",
    "desktop:pack": "npm run ffmpeg:fetch && npm run desktop:build && electron-builder --dir && node scripts/repack-built-app.mjs",
    "desktop:dist": "npm run desktop:pack && electron-builder --prepackaged release/mac-arm64/Nektar.app",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mp4-muxer": "^5.2.2",
    "mp4box": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "webm-muxer": "^5.1.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.4.21",
    "electron": "^37.2.6",
    "electron-builder": "^26.8.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "app.nektar.desktop",
    "productName": "Nektar",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "npmRebuild": false,
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules/**/*",
      "!**/._*"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo"
    }
  }
}
